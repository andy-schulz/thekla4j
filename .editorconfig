# EditorConfig is awesome: https://EditorConfig.org
# This file provides consistent coding styles across different editors and IDEs
# IntelliJ IDEA, VS Code, Eclipse, and many others support EditorConfig

# Top-most EditorConfig file
root = true

# Default settings for all files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Java source files
[*.java]
indent_size = 2
max_line_length = 120
continuation_indent_size = 4

# Kotlin source files
[*.{kt,kts}]
indent_size = 2
max_line_length = 120

# Groovy files
[*.groovy]
indent_size = 2

# Gradle files
[*.gradle]
indent_size = 2

# Gradle Kotlin DSL
[*.gradle.kts]
indent_size = 4

# XML files
[*.xml]
indent_size = 2
max_line_length = 120

# Properties files
[*.properties]
indent_size = 2
max_line_length = 120

# YAML files
[*.{yml,yaml}]
indent_size = 2
max_line_length = 120

# JSON files
[*.json]
indent_size = 2
max_line_length = 120

# Markdown files
[*.md]
indent_size = 2
trim_trailing_whitespace = false
max_line_length = 120

# Shell scripts
[*.sh]
indent_size = 2
end_of_line = lf

# Windows batch files (must use CRLF)
[*.{bat,cmd}]
indent_size = 2
end_of_line = crlf

# PowerShell scripts
[*.ps1]
indent_size = 2
end_of_line = crlf

# Web files
[*.{html,htm}]
indent_size = 2
max_line_length = 120

[*.{css,scss,sass}]
indent_size = 2
max_line_length = 120

[*.{js,jsx,ts,tsx}]
indent_size = 2
max_line_length = 120

# Makefile (must use tabs)
[Makefile]
indent_style = tab
indent_size = 4

[{makefile,Makefile,*.mk}]
indent_style = tab
indent_size = 4

# Git configuration files
[.git{ignore,attributes,modules}]
indent_size = 2
