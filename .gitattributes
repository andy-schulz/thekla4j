# Normalize line endings to LF for all text files
# This ensures consistent line endings across Windows, Linux, and macOS

# Auto-detect text files and normalize to LF
* text=auto eol=lf

# Source code
*.java text eol=lf
*.groovy text eol=lf
*.gradle text eol=lf
*.kt text eol=lf
*.kts text eol=lf

# Configuration files
*.xml text eol=lf
*.properties text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.conf text eol=lf

# Documentation
*.md text eol=lf
*.txt text eol=lf
*.adoc text eol=lf
*.rst text eol=lf

# Web files
*.html text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.jsx text eol=lf
*.tsx text eol=lf

# Scripts
*.sh text eol=lf
*.bash text eol=lf

# Windows-specific files (must use CRLF)
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Git files
.gitattributes text eol=lf
.gitignore text eol=lf
.gitmodules text eol=lf

# Binary files (should not be normalized)
*.jar binary
*.zip binary
*.tar.gz binary
*.tgz binary
*.gz binary
*.7z binary
*.rar binary
*.exe binary
*.dll binary
*.so binary
*.dylib binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.pdf binary
*.class binary
*.war binary
*.ear binary
